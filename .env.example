# ==========================================
# CẤU HÌNH BIẾN MÔI TRƯỜNG DỰ ÁN
# ==========================================

# 1. SUPABASE (Lấy tại mục Project Settings -> API)
# Dùng cho cả Frontend (NEXT_PUBLIC) và Backend
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# CHỈ DÀNH CHO BACKEND (Cực kỳ bảo mật - Dùng để bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# 2. RESEND (Gửi Email tự động)
RESEND_API_KEY=your_resend_api_key

# 3. CLOUDINARY (Lưu trữ hình ảnh)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret